# Copy to .env and fill in. Never commit .env (see repo root .gitignore).
#
# --- WebView target (required for real devices / APK builds)
# LAN + Vite on your PC:  http://192.168.x.x:5173  (your PC's Wi‑Fi IP, no trailing slash)
# Deployed site:          https://your-domain.example
EXPO_PUBLIC_HEALHUB_URL=

# Match healhub/.env (Supabase → Settings → API). Required if native code imports supabase.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- EAS cloud builds (.env is NOT uploaded — set vars for the build):
#   expo.dev → Project → Environment variables  (Preview / Production)
#   or:  npx eas secret:create --scope project --name EXPO_PUBLIC_HEALHUB_URL --value "https://..."
# Same names as above: EXPO_PUBLIC_HEALHUB_URL, EXPO_PUBLIC_SUPABASE_URL, EXPO_PUBLIC_SUPABASE_ANON_KEY

# --- One-time Android APK workflow (from this folder):
#   npm install
#   npx eas login
#   npx eas init          # links project; writes projectId into app.json
#   npm run build:android
# On each phone: allow install from your file/browser app; open the downloaded .apk
