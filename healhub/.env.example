VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Owner AI (Ollama) — default ON if unset. Set to false to hide the tile + floating assistant.
# VITE_ENABLE_OWNER_AI=false
#
# Customer shopping assistant (same bridge as Owner AI). Default ON if unset.
# VITE_ENABLE_CUSTOMER_AI=false
#
# When enabled, run Ollama + in a second terminal: npm run server:dev
# Server env (same .env file):
# OLLAMA_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2
# OWNER_AI_PORT=8787
# Max recent orders included in Owner AI context (default 45, max 200). Same customer column logic as Analytics.
# OWNER_AI_RECENT_ORDERS_LIMIT=45
# Shrink injected JSON if prompts exceed limits (default 8800).
# OWNER_AI_PAYLOAD_JSON_MAX=8800
# Max characters per message sent to Ollama after building system context (default 16000).
# OWNER_AI_MAX_MESSAGE_CHARS=16000
#
# Customer AI (same server:dev process)
# CUSTOMER_AI_TEMPERATURE=0.4
# CUSTOMER_AI_RECENT_ORDERS_LIMIT=40
# CUSTOMER_AI_PRODUCTS_LIMIT=100
# CUSTOMER_AI_PAYLOAD_JSON_MAX=8800

# Optional: public URL of this app (no trailing slash). Use your PC LAN IP when testing on a phone
# (e.g. http://172.20.10.4:5173). Required so "Forgot password" emails link somewhere the phone can open.
# Add the same URL in Supabase → Authentication → URL Configuration → Redirect URLs.
# VITE_PUBLIC_SITE_URL=http://YOUR_PC_LAN_IP:5173

# Production / mobile WebView: public origin of the AI Express bridge (https, no trailing slash).
# This repo includes healhub/.env.production so `vite build` targets the Railway bridge by default.
# Override with VITE_AI_BRIDGE_URL on the CI host if needed. Leave unset locally — Vite proxies /api to server:dev.
# Deploy healhub/server (Railway, Render, Fly, VPS), set SUPABASE_* + OLLAMA_URL there, then:
# VITE_AI_BRIDGE_URL=https://your-bridge-host.example.com
# On the bridge, restrict browsers with (comma-separated):
# OWNER_AI_CORS_ORIGIN=https://your-app.vercel.app
